# Stripe — CCNA Timed Test Simulation (Checkout + webhook)
# Copy to .env.local for local CLI testing; set the same keys in Vercel → Project → Settings → Environment Variables.
#
# STRIPE_SECRET_KEY must be the Secret key (sk_test_… / sk_live_…) from Developers → API keys,
# or a Restricted key (rk_test_… / rk_live_…) with permission for Checkout. Not mk_, pk_, or whsec_.
# Webhook signing secret (whsec_…) goes in STRIPE_WEBHOOK_SECRET only.
# Use the secret from the webhook whose URL is THIS site (e.g. https://becertifiedtoday.com/api/stripe-webhook).
# If you use one Stripe account for multiple deployments, add a separate webhook endpoint per site and put each whsec_ here.

STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# One-time Price for the simulated test (Stripe Dashboard → Products → Price ID)
STRIPE_PRICE_CCNA_TEST_SIM=price_xxxxxxxx

# Site origin for Checkout success/cancel redirects. Must match how users open the site (www vs apex).
# Code adds https:// if missing and strips paths/trailing slashes/stray quotes.
PUBLIC_SITE_URL=https://becertifiedtoday.com

# Stripe Payment Links for CCNA portal access (optional). If unset, the API uses the default buy.stripe.com URLs.
# Dashboard → Payment Links → copy link. Must be https://buy.stripe.com/…
# STRIPE_PAYMENT_LINK_CCNA_PORTAL_10D=https://buy.stripe.com/xxxx
# STRIPE_PAYMENT_LINK_CCNA_PORTAL_30D=https://buy.stripe.com/xxxx

# ENCOR portal Payment Links (client-side in encor-portal-30d-checkout.js unless overridden later).
# Stripe Dashboard → each Payment Link → After payment → Redirect to a custom URL:
#   https://becertifiedtoday.com/CCNP-ENCOR-Study/ENCOR_Training_Portal.html?session_id={CHECKOUT_SESSION_ID}
# ENCOR timed test Payment Link success URL:
#   https://becertifiedtoday.com/CCNP-ENCOR-Study/test-simulation.html?session_id={CHECKOUT_SESSION_ID}
# Add metadata productId on each link when possible: encor-portal-10d, encor-portal-30d, encor-test-simulation

# Price IDs for /api/create-checkout-session and webhook product inference (match Payment Link products).
# STRIPE_PRICE_CCNA_PORTAL_10D=price_xxxxxxxx
# STRIPE_PRICE_CCNA_PORTAL_30D=price_xxxxxxxx
# STRIPE_PRICE_ENCOR_PORTAL_10D=price_xxxxxxxx
# STRIPE_PRICE_ENCOR_PORTAL_30D=price_xxxxxxxx
# STRIPE_PRICE_ENCOR_TEST_SIM=price_xxxxxxxx
# STRIPE_PRICE_SECPLUS_PORTAL_10D=price_xxxxxxxx
# STRIPE_PRICE_SECPLUS_PORTAL_30D=price_xxxxxxxx
# STRIPE_PRICE_SECPLUS_TEST_SIM=price_xxxxxxxx

# ----- Portal magic-link email (same pattern as other Be Certified Today portals; optional but recommended) -----
# Webhook checkout.session.completed writes Stripe Customer metadata and emails a signed link via Resend.
PORTAL_MAGIC_LINK_SECRET=
# Generate with: openssl rand -hex 32

RESEND_API_KEY=
RESEND_FROM=Be Certified Today <noreply@your-verified-domain.com>
# RESEND_CCNA_PORTAL_SUBJECT=Your CCNA training portal link
# RESEND_ENCOR_PORTAL_SUBJECT=Your ENCOR training portal link
# RESEND_SECPLUS_PORTAL_SUBJECT=Your Security+ training portal link

# Marketing lead magnet (Security+ study plan email capture)
# Optional Resend Audience ID → Dashboard → Audiences → copy ID
# RESEND_SECPLUS_MARKETING_AUDIENCE_ID=
# RESEND_SECPLUS_STUDY_PLAN_SUBJECT=Your free SY0-701 domain study plan
# RESEND_SECPLUS_FREE_SIM_SUBJECT=Your free Security+ simulation is ready
# RESEND_SECPLUS_SCORECARD_SUBJECT=Your Security+ SY0-701 simulation scorecard

# Lead CSV → marketing-vault/leads/ (synced via git)
# Production: GitHub fine-grained PAT with Contents read/write on this repo
# GITHUB_LEADS_TOKEN=ghp_…
# GITHUB_LEADS_REPO=your-user/CCNP_Study_main
# Optional override path (default marketing-vault/leads/secplus-free-simulation-leads.csv)
# LEADS_CSV_PATH=marketing-vault/leads/secplus-free-simulation-leads.csv
# Local vercel dev appends to the file on disk when GITHUB_LEADS_TOKEN is unset
# Visitor footer questions → marketing-vault/leads/visitor-questions.csv (same token)

# --- After payment ---
# • If payment succeeds but the browser never lands on the timed test, set PUBLIC_SITE_URL to the exact
#   origin you use (e.g. https://www.becertifiedtoday.com vs https://becertifiedtoday.com).
# • Stripe receipt emails (Dashboard → Settings → Emails) are separate from portal magic links.
# • Magic links require STRIPE_WEBHOOK_SECRET on THIS deployment, PORTAL_MAGIC_LINK_SECRET, PUBLIC_SITE_URL,
#   RESEND_API_KEY + RESEND_FROM, and purchaser email from Checkout / Payment Link (enable email collection).
# • Users can request another email from /CCNA-Study/ccna-portal-request-link.html while access is active.

# ----- Vercel Web Analytics (dashboard only; no env vars) -----
# Vercel project → Analytics → Enable Web Analytics, then redeploy.
# Tracking script: /js/install-vercel-analytics.js → /_vercel/insights/script.js

# ----- Google Analytics 4 (site tagging + /admin dashboard) -----
# GA_MEASUREMENT_ID: Admin → Data streams → Web → Measurement ID (G-XXXXXXXX)
GA_MEASUREMENT_ID=G-YTT6KBHX7V
# GA_PROPERTY_ID: numeric Property ID (Admin → Property settings), not the G- ID
GA_PROPERTY_ID=123456789
# Service account for Data API (run: ./scripts/format-ga-service-account-for-vercel.sh key.json)
# Recommended on Vercel (avoids broken JSON paste): GA_SERVICE_ACCOUNT_JSON_B64=<output from script>
# Or single line: GA_SERVICE_ACCOUNT_JSON=$(jq -c . key.json)
# Or split: GA_SERVICE_ACCOUNT_CLIENT_EMAIL + GA_SERVICE_ACCOUNT_PRIVATE_KEY (+ PROJECT_ID)
# Enable Google Analytics Data API; grant SA on property (scripts/grant-ga4-service-account-access.sh).

# Admin dashboard at /admin (email + password + JWT for API)
# Portal subscriber list uses the same admin JWT + STRIPE_SECRET_KEY (Stripe customer metadata).
# Portal bypass links (training portals) require the same admin JWT + ADMIN_ANALYTICS_JWT_SECRET.
ADMIN_ANALYTICS_EMAIL=georgecwerbacher@gmail.com
ADMIN_ANALYTICS_PASSWORD=
ADMIN_ANALYTICS_JWT_SECRET=
# Generate JWT secret: openssl rand -hex 32

# ----- Marketing vault (in-repo) -----
# Weekly GA4 snapshot → marketing-vault/03-reports/weekly/
#   npm run marketing:weekly-report
