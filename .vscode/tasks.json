{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve site (localhost:3000)",
      "type": "npm",
      "script": "serve",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Accepting connections"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    },
    {
      "label": "Open current HTML in browser (localhost:3000)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/open-localhost.sh",
      "args": ["${file}"],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    }
  ]
}
