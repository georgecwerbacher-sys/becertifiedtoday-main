{
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/ccna-index.html",
      "destination": "/CCNA-Study/CCNA_Training_Portal.html",
      "permanent": true
    },
    {
      "source": "/CCNA-Study/ccna-index.html",
      "destination": "/CCNA-Study/CCNA_Training_Portal.html",
      "permanent": true
    },
    {
      "source": "/CCNP_Encor.html",
      "destination": "/CCNP-ENCOR-Study/ENCOR_Training_Portal.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/ccna-portal-request-magic-link",
      "destination": "/api/portal-request-magic-link?track=ccna"
    },
    {
      "source": "/api/encor-portal-request-magic-link",
      "destination": "/api/portal-request-magic-link?track=encor"
    },
    {
      "source": "/api/ccna-portal-redeem-magic",
      "destination": "/api/portal-redeem-magic"
    },
    {
      "source": "/api/encor-portal-redeem-magic",
      "destination": "/api/portal-redeem-magic"
    },
    {
      "source": "/api/ccna-portal-10d-payment-link",
      "destination": "/api/ccna-portal-payment-link?plan=10d"
    },
    {
      "source": "/api/ccna-portal-30d-payment-link",
      "destination": "/api/ccna-portal-payment-link?plan=30d"
    },
    {
      "source": "/admin",
      "destination": "/admin/analytics.html"
    },
    {
      "source": "/admin/analytics",
      "destination": "/admin/analytics.html"
    },
    {
      "source": "/sample",
      "destination": "/CCNP-ENCOR-Study/ENCOR_Samples/sample.html"
    },
    {
      "source": "/CCNA_Sim_EXAM/embed/dnd/:path*",
      "destination": "/CCNA-Study/CCNA_D_D/:path*"
    },
    {
      "source": "/CCNA_Sim_EXAM/embed/lab/:file",
      "destination": "/CCNA-Study/CCNA_labs/:file"
    },
    {
      "source": "/ccna/practice-test",
      "destination": "/ccna-home.html"
    }
  ]
}
