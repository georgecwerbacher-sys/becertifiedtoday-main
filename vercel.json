{
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/admin",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive, nosnippet"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/begin-test-simulation.html",
      "destination": "/CCNP-ENCOR-Study/begin-test-simulation.html",
      "permanent": true
    },
    {
      "source": "/encor/test-simulation.html",
      "destination": "/CCNP-ENCOR-Study/test-simulation.html",
      "permanent": true
    },
    {
      "source": "/CCNP-ENCOR-Study/free-assessment.html",
      "destination": "/CCNP-ENCOR-Study/test-simulation-runner.html?free=1",
      "permanent": false
    },
    {
      "source": "/ccna-index.html",
      "destination": "/CCNA-Study/CCNA_Training_Portal.html",
      "permanent": true
    },
    {
      "source": "/CCNA-Study/ccna-index.html",
      "destination": "/CCNA-Study/CCNA_Training_Portal.html",
      "permanent": true
    },
    {
      "source": "/CCNP_Encor.html",
      "destination": "/CCNP-ENCOR-Study/ENCOR_Training_Portal.html",
      "permanent": true
    },
    {
      "source": "/admin/analytics",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/admin/analytics.html",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/secplus-home.html",
      "destination": "/comptia-sec+-home.html",
      "permanent": true
    },
    {
      "source": "/choose-training-path.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/ccna-portal-request-magic-link",
      "destination": "/api/portal-request-magic-link?track=ccna"
    },
    {
      "source": "/api/encor-portal-request-magic-link",
      "destination": "/api/portal-request-magic-link?track=encor"
    },
    {
      "source": "/api/secplus-portal-request-magic-link",
      "destination": "/api/portal-request-magic-link?track=secplus"
    },
    {
      "source": "/api/ccna-portal-redeem-magic",
      "destination": "/api/portal-redeem-magic"
    },
    {
      "source": "/api/encor-portal-redeem-magic",
      "destination": "/api/portal-redeem-magic"
    },
    {
      "source": "/api/ccna-portal-10d-payment-link",
      "destination": "/api/ccna-portal-payment-link?plan=10d"
    },
    {
      "source": "/api/ccna-portal-30d-payment-link",
      "destination": "/api/ccna-portal-payment-link?plan=30d"
    },
    {
      "source": "/api/analytics-admin-login",
      "destination": "/api/analytics-report"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/sample",
      "destination": "/CCNP-ENCOR-Study/ENCOR_Samples/sample.html"
    },
    {
      "source": "/secplus-sample",
      "destination": "/COMP_TIA_SEC+/SEC+_Samples/sample.html"
    },
    {
      "source": "/CCNA_Sim_EXAM/embed/dnd/:path*",
      "destination": "/CCNA-Study/CCNA_D_D/:path*"
    },
    {
      "source": "/CCNA_Sim_EXAM/embed/lab/:file",
      "destination": "/CCNA-Study/CCNA_labs/:file"
    },
    {
      "source": "/ccna/practice-test",
      "destination": "/ccna-home.html"
    }
  ]
}
